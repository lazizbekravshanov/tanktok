# Required
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Recommended (free)
EIA_API_KEY=your-eia-api-key

# Recommended — Google Maps for truck stop addresses ($200/mo free credit)
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: Crowd-sourced station prices
# CROWD_API_KEY=
# CROWD_API_BASE=

# Optional: Commercial station price feed
# COMMERCIAL_FEED_KEY=
# COMMERCIAL_FEED_BASE=

# Optional: Kalshi prediction markets
# Generate RSA key pair at https://kalshi.com/account/api-keys
# KALSHI_KEY_ID=your-kalshi-key-id
# KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi_private_key.pem
# KALSHI_API_BASE=https://api.elections.kalshi.com
# KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2
# KALSHI_USE_WEBSOCKET=true          # set false for REST-only polling
# KALSHI_POLL_INTERVAL=45            # seconds between REST polls (if WS disabled)

# Optional: Polymarket
# POLYMARKET_API_TOKEN=
# POLYMARKET_API_BASE=https://clob.polymarket.com

# Optional: Nominatim User-Agent
# NOMINATIM_USER_AGENT=TankTok/1.0 (fuel-price-bot)
